@import B

Thing proto
    doStuff fun
    num u32
;

Stuff blob: Thing
    aa u32
    b data<u32, 8>
    c ptr<u32>
    num u32
    doStuff fun
        text blob<@B.String> <- @B.String("in doStuff")
        text.println()

        it.val.num <- 13
    ;
;

@export main fun
    stuff blob<Stuff>
    stuff.num <- 7
    pStuff ptr<blob<Stuff>> <- { stuff.adr }

    thing proto<Thing>
    thing <- { pStuff }

    text blob<@B.String>

    text <- @B.StringForU64(stuff.adr.u64)
    text.println()

    text <- @B.StringForU64(stuff.aa.adr.u64)
    text.println()

    text <- @B.StringForU64(stuff.num.adr.u64)
    text.println()

