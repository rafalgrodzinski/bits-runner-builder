@extern putchar fun: character u32 -> u32

@export String blob
    string data<u8, 64>

    print fun
        rep i u32 <- 0, it.string[i] != '\0' and i < it.string.count, i <- i+1
            putchar(it.string[i])
        ;
    ;

    dummy fun -> u8
        ret it.string[0]
    ;
;

@export String fun: string data<u8, 64> -> blob<String>
    inst blob<String>

    inst.string <- string

    ret inst
;

@export main fun -> u32
    txt blob<String> <- String("hello")
    txt.print()

    ret txt.dummy()
;