@import B

Thing proto
    doStuff fun: newValue u64
    num u32
;

Stuff blob: Thing
    aa u32
    b data<u32, 8>
    c ptr<u32>
    num u32
    doStuff fun: newValue u32
        text blob<@B.String> <- @B.String("in doStuff")
        text.println()

        it.val.num <- newValue
    ;
;

@export main fun
    stuff blob<Stuff>
    stuff.num <- 7
    pStuff ptr<blob<Stuff>> <- { stuff.adr }

    thing proto<Thing>
    thing <- { pStuff }

    text blob<@B.String>

    /*text <- @B.StringForU64(stuff.doStuff.adr.u64)
    text.println()

    text <- @B.StringForU64(thing.doStuff.adr.u64)
    text.println()*/

    //stuff.doStuff(42)
    thing.doStuff(66)

    text <- @B.StringForU32(stuff.num)
    text.println()
;

