Thing proto
    doStuff fun
    num u32
;

Stuff blob: Thing
    aa u32
    b data<u32, 8>
    c ptr<u32>
    num u32
    doStuff fun
    ;
;

@export main fun
    stuff blob<Stuff>
    pStuff ptr<blob<Stuff>> <- { stuff.adr }

    thing proto<Thing>
    thing <- { pStuff }
    thing.vadr
    //thing.doStuff()
;

