    newUser( { userPtr.adr }, "Alice", 9)
    newUser( { userPtr.adr }, "Mike", 3)
    newUser( { userPtr.adr }, "Kuma", 666)*/

    printUsers(userPtr)

    ret 0
;*/

doStuff fun: pNum ptr<u32> -> u32
    ret pNum.val
;

@export main fun -> u32
    num u32 <- 7
    pNum ptr<u32> <- {num.adr}
    ret doStuff(pNum)
;