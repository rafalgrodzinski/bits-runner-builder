@module Lib

@import B

@export Shape proto
    name blob<@B.String>
    getArea fun -> u32
;

@export printShape fun: shape proto<Shape>
    text blob<@B.String>

    text <- @B.String("Area of ")
    text.print()

    shape.name.print()

    text <- @B.String(" is ")
    text.print()

    text <- @B.StringForU32(shape.getArea())
    text.println()
;